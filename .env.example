REDIS_URL=redis://localhost:6379

REAL_PROVIDER_APIS_ENABLED=false
WEBHOOK_SIGNING_SECRET=whsec_local_fake_secret_do_not_use
DOWNSTREAM_API_BASE_URL=http://localhost:3999/mock-downstream
