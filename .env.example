# Local-only development values. Do not use real provider credentials here.

# Runtime mode for local API, worker, simulator, and tests. Required by app config.
NODE_ENV=development

# Structured log verbosity for local services. Required only when overriding the default.
LOG_LEVEL=debug

# Hono API bind host for local development. Optional; safe default is localhost.
API_HOST=localhost

# Hono API port for local development. Optional; safe default is 3000.
API_PORT=3000

# Maximum webhook request body size in bytes. Optional; local default is 1 MiB.
WEBHOOK_MAX_BODY_BYTES=1048576

# Local in-memory webhook rate-limit window in milliseconds. Optional local guardrail.
WEBHOOK_RATE_LIMIT_WINDOW_MS=60000

# Max webhook requests per provider/client key within the local rate-limit window. Optional.
WEBHOOK_RATE_LIMIT_MAX_REQUESTS=120

# Local Docker PostgreSQL URL used by API, worker, migrations, tests, and scripts. Required locally.
DATABASE_URL=postgres://webhook_monitor:webhook_monitor_password@localhost:5432/webhook_monitor

# Local Docker PostgreSQL database name. Required by infra/docker-compose.yml.
POSTGRES_DB=webhook_monitor

# Local Docker PostgreSQL user. Required by infra/docker-compose.yml.
POSTGRES_USER=webhook_monitor

# Fake local PostgreSQL password. Required by infra/docker-compose.yml; not a real secret.
POSTGRES_PASSWORD=webhook_monitor_password

# Local Docker PostgreSQL host port. Required by infra/docker-compose.yml.
POSTGRES_PORT=5432

# Local Docker Redis URL used by API, worker, queue, and simulator flows. Required locally.
REDIS_URL=redis://localhost:6379

# Number of BullMQ delivery jobs the worker may process concurrently. Optional local default.
WORKER_CONCURRENCY=2

# Maximum delivery attempts before retry exhaustion dead-letters an event. Optional local default.
DELIVERY_MAX_ATTEMPTS=3

# Initial BullMQ retry delay in milliseconds. Optional local default.
DELIVERY_INITIAL_DELAY_MS=1000

# Exponential backoff multiplier for retry delays. Optional local default.
DELIVERY_BACKOFF_MULTIPLIER=2

# Maximum retry delay in milliseconds. Optional local default.
DELIVERY_MAX_DELAY_MS=30000

# Worker mock downstream mode. Required locally; only payload-driven is implemented.
MOCK_DOWNSTREAM_MODE=payload-driven

# Display/audit target URL for local mock downstream attempts. Required by worker config.
MOCK_DOWNSTREAM_URL=http://localhost:3000/mock-downstream/deliver

# Safety flag documenting that real provider APIs are disabled in this local project.
REAL_PROVIDER_APIS_ENABLED=false

# Reserved fake signing value for future generic signing examples. Not used by current runtime.
WEBHOOK_SIGNING_SECRET=whsec_local_fake_secret_do_not_use

# Fake local Stripe-style sample webhook secret. Required for stripe-sample verification and simulator signing.
STRIPE_SAMPLE_WEBHOOK_SECRET=whsec_local_test_secret

# Reserved fake downstream base URL for documentation/experiments. Not used by current worker runtime.
DOWNSTREAM_API_BASE_URL=http://localhost:3999/mock-downstream

# Local API base URL used by simulator commands. Optional local default.
SIMULATOR_API_BASE_URL=http://localhost:3000

# Simulator HTTP request timeout in milliseconds. Optional local default.
SIMULATOR_TIMEOUT_MS=10000

# Simulator polling timeout for async worker/dashboard observations. Optional local default.
SIMULATOR_POLL_TIMEOUT_MS=30000

# Simulator polling interval in milliseconds. Optional local default.
SIMULATOR_POLL_INTERVAL_MS=500
