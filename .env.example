# Local-only development values. Do not use real provider credentials here.
NODE_ENV=development
LOG_LEVEL=debug
API_HOST=localhost
API_PORT=3000
WEBHOOK_MAX_BODY_BYTES=1048576
WEBHOOK_RATE_LIMIT_WINDOW_MS=60000
WEBHOOK_RATE_LIMIT_MAX_REQUESTS=120

DATABASE_URL=postgres://webhook_monitor:webhook_monitor_password@localhost:5432/webhook_monitor
POSTGRES_USER=webhook_monitor
POSTGRES_PASSWORD=webhook_monitor_password
POSTGRES_DB=webhook_monitor
POSTGRES_PORT=5432

REDIS_URL=redis://localhost:6379
WORKER_CONCURRENCY=2
DELIVERY_MAX_ATTEMPTS=3
DELIVERY_INITIAL_DELAY_MS=1000
DELIVERY_BACKOFF_MULTIPLIER=2
DELIVERY_MAX_DELAY_MS=30000
MOCK_DOWNSTREAM_MODE=payload-driven
MOCK_DOWNSTREAM_URL=http://localhost:3000/mock-downstream/deliver

REAL_PROVIDER_APIS_ENABLED=false
WEBHOOK_SIGNING_SECRET=whsec_local_fake_secret_do_not_use
STRIPE_SAMPLE_WEBHOOK_SECRET=whsec_local_test_secret
DOWNSTREAM_API_BASE_URL=http://localhost:3999/mock-downstream

SIMULATOR_API_BASE_URL=http://localhost:3000
SIMULATOR_TIMEOUT_MS=10000
SIMULATOR_POLL_TIMEOUT_MS=30000
SIMULATOR_POLL_INTERVAL_MS=500
