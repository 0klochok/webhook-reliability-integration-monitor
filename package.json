{
  "name": "webhook-reliability-integration-monitor",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=24.16.0",
    "pnpm": ">=11.7.0"
  },
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "dev:api": "pnpm --filter @webhook-monitor/api dev",
    "dev:worker": "pnpm --filter @webhook-monitor/worker dev",
    "api:test": "pnpm --filter @webhook-monitor/api test",
    "api:typecheck": "pnpm --filter @webhook-monitor/api typecheck",
    "worker:test": "pnpm --filter @webhook-monitor/worker test",
    "queue:test": "pnpm --filter @webhook-monitor/queue test",
    "queue:reset": "pnpm --filter @webhook-monitor/queue queue:reset",
    "db:generate": "pnpm --filter @webhook-monitor/db db:generate",
    "db:migrate": "pnpm --filter @webhook-monitor/db db:migrate",
    "db:reset": "pnpm --filter @webhook-monitor/db db:reset",
    "db:seed": "pnpm --filter @webhook-monitor/db db:seed",
    "db:studio": "pnpm --filter @webhook-monitor/db db:studio",
    "demo:reset": "pnpm db:reset && pnpm queue:reset",
    "demo:seed": "pnpm db:seed",
    "demo:run": "pnpm simulator:all",
    "simulator:stripe-valid": "pnpm --filter @webhook-monitor/simulator start -- stripe-valid",
    "simulator:success": "pnpm --filter @webhook-monitor/simulator start -- success",
    "simulator:duplicate": "pnpm --filter @webhook-monitor/simulator start -- duplicate",
    "simulator:invalid-signature": "pnpm --filter @webhook-monitor/simulator start -- invalid-signature",
    "simulator:invalid-payload": "pnpm --filter @webhook-monitor/simulator start -- invalid-payload",
    "simulator:mock-crm-success": "pnpm --filter @webhook-monitor/simulator start -- mock-crm-success",
    "simulator:retry-success": "pnpm --filter @webhook-monitor/simulator start -- retry-success",
    "simulator:dead-letter": "pnpm --filter @webhook-monitor/simulator start -- dead-letter",
    "simulator:permanent-failure": "pnpm --filter @webhook-monitor/simulator start -- permanent-failure",
    "simulator:manual-replay": "pnpm --filter @webhook-monitor/simulator start -- manual-replay",
    "simulator:all": "pnpm --filter @webhook-monitor/simulator start -- all",
    "docker:up": "docker compose -f .\\infra\\docker-compose.yml up -d",
    "docker:down": "docker compose -f .\\infra\\docker-compose.yml down",
    "docker:ps": "docker compose -f .\\infra\\docker-compose.yml ps"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  }
}
